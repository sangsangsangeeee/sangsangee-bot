# Telegram bot token from @BotFather
BOT_TOKEN=

# Where specs are written. Points at the meta-repo's inbox parent (the `specs/` dir).
# The bot writes into `${SPECS_DIR}/inbox/<slug>/`.
SPECS_DIR=../meta-repo/specs

# Comma-separated Telegram numeric user IDs allowed to use the bot.
# Empty = allow everyone (fine for local dev only).
ALLOWLIST=

# Commit each new spec to git in the meta-repo (true/false).
GIT_COMMIT=false

# Claude subscription OAuth token from `claude setup-token` (1-year, sk-ant-oat...).
# Enables AI spec extraction via the Agent SDK on your subscription (no API key).
# IMPORTANT: do NOT also set ANTHROPIC_API_KEY — it takes precedence and bills the API.
CLAUDE_CODE_OAUTH_TOKEN=

# Model for spec extraction (default claude-sonnet-4-6; claude-opus-4-8 for higher quality).
AI_MODEL=claude-sonnet-4-6
